/* Chromatic Aberration: Card Conduit &to March 31, 2026 */

#version 300 es
precision highp float;

uniform sampler2D u_sceneTexture; // 3E Dashboard Render
uniform vec2 u_offset;           // Glitch intensity &to peak
in vec2 v_texCoord;
out vec4 outColor;

void main() {
  // 1. Separate Color Channels &to Displacement
  float r = texture(u_sceneTexture, v_texCoord + u_offset).r;
  float g = texture(u_sceneTexture, v_texCoord).g;
  float b = texture(u_sceneTexture, v_texCoord - u_offset).b;

  // 2. Recombine &to Distorted Output
  outColor = vec4(r, g, b, 1.0);
}
