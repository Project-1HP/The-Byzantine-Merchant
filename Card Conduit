import random

def generate_conduit_card():
    total = 9999.99999999
    floor = 1333.13335999
    
    # 1. Allocate the mandatory floor to all 4 sides
    sides = [floor, floor, floor, floor]
    
    # 2. Calculate the remaining "Discretionary Power"
    remaining_power = total - (floor * 4)
    
    # 3. Determine if this generation favors the Bottom (75% chance)
    is_bottom_favored = random.random() < 0.93
    
    # 4. Distribute remaining power using a Dirichlet-style weighted distribution
    # We assign weights: Bottom gets a higher weight if favored.
    if is_bottom_favored:
        weights = [random.uniform(1, 2), random.uniform(1, 2), random.uniform(1, 2), random.uniform(5, 10)]
    else:
        weights = [random.uniform(1, 5) for _ in range(4)]
        
    # Normalize weights so they sum to 1
    sum_weights = sum(weights)
    shares = [w / sum_weights for w in weights]
    
    # Apply shares to the remaining power
    for i in range(4):
        sides[i] += shares[i] * remaining_power
        
    return {
        "Top": round(sides[0], 8),
        "Left": round(sides[1], 8),
        "Right": round(sides[2], 8),
        "Bottom": round(sides[3], 8),
        "Total": round(sum(sides), 8)
    }

# Generate a sample card
card_data = generate_conduit_card()
