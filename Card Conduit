import random

def generate_top_weighted_card():
    total_power = 9.99999999
    positions = ["Top", "Left", "Right", "Bottom"]
    colors = ["Red", "Blue", "Purple", "Green", "Yellow", "Orange", "White", "Black"]
    
    # Shuffle colors so they aren't tied to a specific position
    random.shuffle(colors)
    
    # 1. Assign weights. Top gets a higher range (e.g., 5-10) 
    # while others get a lower range (e.g., 1-5).
    # This creates a 'higher probability' without making it absolute.
    weights = [
        random.uniform(1.0, 5.0),  # Top weight
        random.uniform(1.0, 5.0),  # Left weight
        random.uniform(1.0, 5.0),  # Right weight
        random.uniform(1.0, 5.0)   # Bottom weight
    ]
    
    # 2. Normalize weights to sum to 1.0
    sum_weights = sum(weights)
    shares = [w / sum_weights for w in weights]
    
    # 3. Map to positions
    card_data = {}
    for i in range(4):
        card_data[positions[i]] = {
            "Color": colors[i],
            "Value": round(shares[i] * total_power, 8)
        }
    
    return card_data

# Generate a sample
card = generate_top_weighted_card()
print(f"{'Position':<10} | {'Color':<10} | {'Value'}")
print("-" * 35)
for pos, data in card.items():
    print(f"{pos:<10} | {data['Color']:<10} | {data['Value']}")
    
