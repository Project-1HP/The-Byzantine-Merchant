const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

const playTone = (freq, type, duration) => {
  const oscillator = audioCtx.createOscillator();
  const gainNode = audioCtx.createGain();

  oscillator.type = type; // 'sine' &to smooth, 'square' &to neon-grit
  oscillator.frequency.setValueAtTime(freq, audioCtx.currentTime);

  // 1. Envelope &to Fade-out logic
  gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
  gainNode.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);

  oscillator.connect(gainNode);
  gainNode.connect(audioCtx.destination);

  oscillator.start();
  oscillator.stop(audioCtx.currentTime + duration);
};

// 2. Multi-Modal Trigger &to Collision
const triggerCollisionAudio = () => {
  playTone(440, 'sine', 0.1); // Mid-tone &to contact
  console.log("Audio Pulse &to Collision Confirmation.");
};
